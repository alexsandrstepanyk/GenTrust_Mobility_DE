# GENTRUST MOBILITY - Environment Configuration
# Generated: 2026-03-08

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Security (КРИТИЧНО: змініть на реальний секрет!)
JWT_SECRET=gentrust-super-secret-jwt-key-2026-do-not-share-this-key-ever
JWT_EXPIRES_IN=7d

# Database (SQLite для розробки)
DATABASE_URL="file:./prisma/dev.db"

# Redis (опціонально, для кешування)
# Якщо Redis не встановлено, кешування не працюватиме
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary (опціонально, для фото)
# Зареєструйтесь на https://cloudinary.com для отримання ключів
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini AI
GEMINI_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5180,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
