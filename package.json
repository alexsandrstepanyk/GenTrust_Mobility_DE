{
  "name": "gentrust-alpha-bot",
  "version": "1.0.0",
  "description": "GenTrust Alpha Telegram Bot MVP",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 nodemon src/index.ts",
    "api": "NODE_OPTIONS=--max-old-space-size=4096 nodemon src/api.ts",
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate:department": "prisma generate --schema=./prisma/schema_departments.prisma",
    "prisma:migrate:department": "bash scripts/init_department_dbs.sh"
  },
  "keywords": [
    "telegram",
    "bot",
    "gentrust",
    "ai",
    "gemini"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "@prisma/client": "^5.10.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "expo-device": "^8.0.10",
    "expo-notifications": "^0.32.16",
    "express": "^5.2.1",
    "fs-extra": "^11.3.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "telegraf": "^4.15.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.19",
    "@types/react": "~19.1.10",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "md-to-pdf": "^5.2.5",
    "nodemon": "^3.0.3",
    "prisma": "^5.10.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
