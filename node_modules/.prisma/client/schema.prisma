// Prisma Schema (schema.prisma)
// Налаштування підключення (для прототипу використовуємо SQLite, для релізу — PostgreSQL)
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// 1. УЧАСНИКИ СИСТЕМИ
model User {
  id           String  @id @default(uuid())
  telegramId   BigInt? @unique
  email        String? @unique
  passwordHash String?
  username     String?
  firstName    String?
  lastName     String?
  birthDate    String? // DD.MM.YYYY
  school       String?
  grade        String? // Клас/Група
  phone        String? // Contact phone number
  address      String? // Home address

  role     String  @default("SCOUT") // Role: SCOUT, ADMIN, MODERATOR, PARENT
  status   String  @default("PENDING") // Status: PENDING, ACTIVE, PROBATION, BLOCKED
  language String? @default("uk")

  // Показники
  dignityScore      Int       @default(50)
  balance           Float     @default(0.0)
  district          String? // Район (напр. Zellerau)
  city              String? // Місто (напр. Würzburg)
  country           String?   @default("DE") // Країна для масштабування
  urbanBanExpiresAt DateTime? // Блокування доступу до Urban Guardian

  // Push notifications
  pushToken String? // Expo push token for notifications

  // Батькові зв'язки
  parentRelations ParentChild[]  @relation("parent")
  childRelations  ParentChild[]  @relation("child")
  personaltasks   PersonalTask[] @relation("creator")

  // Зв'язки
  reports      Report[] // Звіти про поламки
  quests       Quest[] // Виконані доставки
  taskOrders   TaskOrder[]
  activities   ActivityRecord[]
  bioReports   BioReport[]
  gpsLocations GPSLocation[]

  // Виконання завдань
  completedTasks TaskCompletion[] @relation("completedBy") // Завдання виконані цим користувачем
  verifiedTasks  TaskCompletion[] @relation("verifiedBy") // Завдання підтверджені цим користувачем

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1B. ЗӘЯЗОК БАТЬКО-ДИТИНА
model ParentChild {
  id       String @id @default(uuid())
  parent   User   @relation("parent", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String
  child    User   @relation("child", fields: [childId], references: [id], onDelete: Cascade)
  childId  String

  // Управління дозволами
  status       String    @default("PENDING") // PENDING (очікує підтвердження батька), APPROVED, BLOCKED, REJECTED
  approvalCode String? // Код для підтвердження реєстрації
  approvedAt   DateTime?
  approvedBy   String? // userID того хто підтвердив

  // Налаштування контролю
  canTrackGPS    Boolean @default(true)
  canViewQuests  Boolean @default(true)
  canCreateTasks Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, childId])
}

// 1C. GPS ЛОКАЦІЇ ДИТИНИ
model GPSLocation {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
}

// 1D. ПЕРСОНАЛЬНІ ЗАВДАННЯ (від батьків для дітей)
model PersonalTask {
  id        String @id @default(uuid())
  creator   User   @relation("creator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  title       String
  description String?
  status      String  @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  reward      Float? // Грошова винагорода або Dignity Score

  // Аудиторія завдання
  audience        String  @default("PERSONAL") // PERSONAL (тільки для однієї дитини), GLOBAL (для всіх своїх дітей)
  assignedChildId String? // Якщо PERSONAL, то ID конкретної дитини

  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId, audience])
  @@index([assignedChildId])
}

// 2. ПРОВАЙДЕРИ ЗАВДАНЬ (Бізнес, Школи)
model Provider {
  id         String  @id @default(uuid())
  telegramId BigInt  @unique
  name       String
  type       String  @default("BUSINESS") // Type: BUSINESS, SCHOOL, GOV
  city       String?
  quests     Quest[]

  status    String   @default("PENDING") // Status: PENDING, ACTIVE, REJECTED, BANNED
  createdAt DateTime @default(now())
}

// 3. ЗВІТИ ПРО ІНФРАСТРУКТУРУ (Urban Guardian)
model Report {
  id       String @id @default(uuid())
  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  photoId     String // ID файлу в Telegram
  description String? // Опис від користувача (якщо ШІ не впевнений)
  latitude    Float
  longitude   Float

  // Робота ШІ та модерація
  aiVerdict       String? // Результат від Gemini (JSON-string)
  category        String? // Категорія проблеми (напр. Дороги, Сміття)
  status          String  @default("PENDING") // ReportStatus: PENDING, APPROVED, REJECTED, FORWARDED
  forwardedTo     String? // Відділ, до якого направлено (roads, lighting, waste, parks, water, transport, other)
  rejectionReason String? // Причина відхилення

  // Зв'язок з комунальною службою
  municipalTask MunicipalTask?

  createdAt DateTime @default(now())
}

// 4. ЗАВДАННЯ (Logistics Scout / Work)
model Quest {
  id          String  @id @default(uuid())
  title       String  @default("Завдання")
  description String?
  type        String  @default("LOGISTICS") // QuestType: LOGISTICS, WORK, VOLUNTEER
  status      String  @default("OPEN") // QuestStatus: OPEN, IN_PROGRESS, COMPLETED, PENDING_VERIFICATION
  reward      Float // Грошова винагорода або Dignity Score

  // Географія
  city     String?
  district String?
  location String? // Текстова адреса

  // Видимість завдання
  isPersonal      Boolean @default(false) // true = тільки для конкретної дитини, false = для всіх
  assignedToChild String? // ID конкретної дитини якщо isPersonal = true

  // Коди безпеки
  pickupCode   String? // Код, щоб забрати (4 digits)
  deliveryCode String? // Код, отримувач каже скауту (4 digits)

  // Локація завершення
  completionLatitude  Float?
  completionLongitude Float?

  // Фото-підтвердження
  requiresPhoto Boolean @default(true) // Чи потрібне фото для підтвердження
  autoApprove   Boolean @default(false) // Автопідтвердження без перевірки

  // Зв'язки
  provider   Provider? @relation(fields: [providerId], references: [id])
  providerId String?

  assignee   User?   @relation(fields: [assigneeId], references: [id])
  assigneeId String?

  taskOrder   TaskOrder? @relation(fields: [taskOrderId], references: [id])
  taskOrderId String?    @unique

  completions TaskCompletion[] // Зв'язок з виконаннями

  createdAt DateTime @default(now())
}

// 4B. ВИКОНАННЯ ЗАВДАНЬ (з фото-підтвердженням)
model TaskCompletion {
  id String @id @default(uuid())

  // Зв'язок з Quest
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  questId String

  // Виконавець
  student   User   @relation("completedBy", fields: [studentId], references: [id])
  studentId String

  // Фото-звіт
  photoUrl        String? // URL фото у Cloudinary/S3/local storage
  photoTelegramId String? // file_id з Telegram (для ботів)
  description     String? // Опис виконаної роботи

  // GPS координати виконання
  latitude  Float?
  longitude Float?

  // Статус підтвердження
  status String @default("PENDING") // PENDING, APPROVED, REJECTED

  // Хто підтверджує (батько або клієнт)
  verifiedBy      User?     @relation("verifiedBy", fields: [verifiedById], references: [id])
  verifiedById    String?
  verifiedAt      DateTime?
  rejectionReason String? // Причина відхилення

  // Винагорода
  rewardAmount Float? // Скільки нараховано
  rewardPaid   Boolean @default(false)

  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([questId, status])
  @@index([studentId, status])
  @@index([status])
}

// 4C. ЗАМОВЛЕННЯ НА ЗАВДАННЯ (від клієнтів у мобільному додатку)
model TaskOrder {
  id          String  @id @default(uuid())
  title       String
  description String?
  subject     String?
  grade       String?
  budget      Float
  city        String?
  district    String?
  location    String?
  status      String  @default("PENDING_MODERATION") // PENDING_MODERATION, APPROVED, REJECTED, PUBLISHED

  requester   User   @relation(fields: [requesterId], references: [id])
  requesterId String

  quest     Quest?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 5. ЖИТТЄПИС ТА ЛОГУВАННЯ ДІЙ
model ActivityRecord {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String // LOGIN, QUEST_COMPLETED, REPORT_APPROVED, REPORT_REJECTED, etc.
  metadata  String? // JSON string
  createdAt DateTime @default(now())
}

model BioReport {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  content        String // Характеристика від Gemini
  rating         String? // A+, B, C etc.
  responsibility Int // 0-100 score
  stability      Int // 0-100 score
  generatedAt    DateTime @default(now())
}

// 6. ІСТОРІЯ РЕЙТИНГУ (Leaderboard Snapshots)
model LeaderboardSnapshot {
  id           String   @id @default(uuid())
  userId       String
  username     String?
  firstName    String?
  dignityScore Int
  city         String?
  district     String?
  school       String?
  rank         Int // Позиція в рейтингу
  snapshotDate DateTime // Дата знімку (без часу)
  createdAt    DateTime @default(now())

  @@index([snapshotDate, rank])
  @@index([userId, snapshotDate])
}

// 7. КОМУНАЛЬНА СЛУЖБА (Municipal Services)
model MunicipalWorker {
  id            String          @id @default(uuid())
  telegramId    BigInt          @unique
  firstName     String?
  lastName      String?
  phone         String?
  department    String? // Відділ (Дороги, Сміття, Освітлення, Парки)
  status        String          @default("PENDING") // PENDING, ACTIVE, BLOCKED
  assignedTasks MunicipalTask[]
  createdAt     DateTime        @default(now())
}

model MunicipalTask {
  id                String           @id @default(uuid())
  report            Report           @relation(fields: [reportId], references: [id])
  reportId          String           @unique
  assignedTo        MunicipalWorker? @relation(fields: [workerId], references: [id])
  workerId          String?
  status            String           @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  priority          String           @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  completedAt       DateTime?
  completionResult  String? // DONE, NO_ISSUE, IMPOSSIBLE
  completionPhotoId String? // proof photo file_id
  completionNote    String?
  createdAt         DateTime         @default(now())
}
