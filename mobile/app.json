{
  "expo": {
    "name": "GenTrust - Client",
    "slug": "gentrust-client",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gentrust.client",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Потрібно для визначення вашого місцезнаходження під час виконання завдань.",
        "NSCameraUsageDescription": "Потрібно для фотографування під час виконання завдань.",
        "NSPhotoLibraryUsageDescription": "Потрібно для вибору фото з галереї."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}